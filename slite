#!/bin/bash

# SimpleLiteDB CLI wrapper

COMMAND=$1
SUBCOMMAND=$2
OPTION=$3

PID_FILE=".slite.pid"
LOG_FILE="slite.log"
VENV_DIR=".venv"

# Pastikan folder data ada
mkdir -p data

# Konfigurasi Port (Default: 5117)
PORT=$(grep "PORT=" .env 2>/dev/null | cut -d'=' -f2)
PORT=${PORT:-5117}

# Tentukan Python yang digunakan (VENV jika ada, jika tidak pakai sistem)
if [ -d "$VENV_DIR" ]; then
    PYTHON_BIN="$VENV_DIR/bin/python3"
    PIP_BIN="$VENV_DIR/bin/pip"
else
    PYTHON_BIN="python3"
    PIP_BIN="pip3"
fi

if [ "$COMMAND" == "start" ] && [ "$SUBCOMMAND" == "db" ]; then
    if [ -f "$PID_FILE" ]; then
        echo "⚠️  SimpleLiteDB is already running (PID: $(cat $PID_FILE))."
        exit 1
    fi
    echo "🚀 Starting SimpleLiteDB Service on port $PORT..."
    nohup $PYTHON_BIN -m uvicorn app:app --host 0.0.0.0 --port $PORT > $LOG_FILE 2>&1 &
    echo $! > $PID_FILE
    echo "✅ Started. Logs are in $LOG_FILE. PID: $(cat $PID_FILE)"

elif [ "$COMMAND" == "stop" ] && [ "$SUBCOMMAND" == "db" ]; then
    if [ ! -f "$PID_FILE" ]; then
        echo "⚠️  SimpleLiteDB is not running."
        exit 1
    fi
    PID=$(cat $PID_FILE)
    echo "🛑 Stopping SimpleLiteDB (PID: $PID)..."
    kill $PID
    rm $PID_FILE
    echo "✅ Stopped."

elif [ "$COMMAND" == "create" ] && [ "$SUBCOMMAND" == "db" ]; then
    echo -n "input db name : "
    read DB_NAME

    if [ -z "$DB_NAME" ]; then
        echo "❌ DB name cannot be empty."
        exit 1
    fi

    if [ ! -f "data/$DB_NAME.db" ]; then
        $PYTHON_BIN -c "import sqlite3; conn = sqlite3.connect('data/$DB_NAME.db'); conn.execute('PRAGMA journal_mode=WAL;'); conn.close()"
        echo "✅ Database '$DB_NAME' created."
    else
        echo "ℹ️  Database '$DB_NAME' already exists."
    fi

    if [ "$OPTION" == "--api" ]; then
        NEW_KEY=$($PYTHON_BIN -c "import secrets; print(secrets.token_urlsafe(32))")

        DB_UPPER=$(echo "$DB_NAME" | tr '[:lower:]' '[:upper:]' | tr '-' '_')
        ENV_VAR="KEY_$DB_UPPER"

        if [ -f ".env" ]; then
            if grep -q "$ENV_VAR=" .env; then
                if [[ "$OSTYPE" == "darwin"* ]]; then
                    sed -i '' "s/$ENV_VAR=.*/$ENV_VAR=$NEW_KEY/" .env
                else
                    sed -i "s/$ENV_VAR=.*/$ENV_VAR=$NEW_KEY/" .env
                fi
            else
                echo "$ENV_VAR=$NEW_KEY" >> .env
            fi
        else
            echo "$ENV_VAR=$NEW_KEY" > .env
        fi

        # Deteksi IP Publik (IPv4)
        PUBLIC_IP=$(curl -s https://api.ipify.org || echo "YOUR_VPS_IP")

        echo ""
        echo "✨ Project Ready!"
        echo "--------------------------"
        echo "slite_url      : http://$PUBLIC_IP:$PORT"
        echo "slite_db_name  : $DB_NAME"
        echo "slite_api_key  : $NEW_KEY"
        echo "--------------------------"
        echo "Key saved to .env as $ENV_VAR"
    fi

elif [ "$COMMAND" == "refresh" ]; then
    DB_NAME=$SUBCOMMAND
    if [ -z "$DB_NAME" ]; then
        echo "❌ Please provide database name: ./slite refresh [db_name]"
        exit 1
    fi
    if [ -f "data/$DB_NAME.db" ]; then
        echo "🔄 Refreshing database '$DB_NAME'..."
        rm "data/$DB_NAME.db"
        $PYTHON_BIN -c "import sqlite3; conn = sqlite3.connect('data/$DB_NAME.db'); conn.execute('PRAGMA journal_mode=WAL;'); conn.close()"
        echo "✅ Database '$DB_NAME' has been reset (empty)."
    else
        echo "❌ Database '$DB_NAME' does not exist."
    fi

elif [ "$COMMAND" == "delete" ]; then
    DB_NAME=$SUBCOMMAND
    if [ -z "$DB_NAME" ]; then
        echo "❌ Please provide database name: ./slite delete [db_name]"
        exit 1
    fi
    echo -n "⚠️  Are you sure you want to delete '$DB_NAME'? This will also remove the API Key. (y/n): "
    read CONFIRM
    if [ "$CONFIRM" == "y" ]; then
        [ -f "data/$DB_NAME.db" ] && rm "data/$DB_NAME.db"
        [ -f "data/$DB_NAME.db-shm" ] && rm "data/$DB_NAME.db-shm"
        [ -f "data/$DB_NAME.db-wal" ] && rm "data/$DB_NAME.db-wal"

        DB_UPPER=$(echo "$DB_NAME" | tr '[:lower:]' '[:upper:]' | tr '-' '_')
        ENV_VAR="KEY_$DB_UPPER"
        if [ -f ".env" ]; then
            if [[ "$OSTYPE" == "darwin"* ]]; then
                sed -i '' "/$ENV_VAR=/d" .env
            else
                sed -i "/$ENV_VAR=/d" .env
            fi
        fi

        echo "✅ Database '$DB_NAME' and its API Key have been deleted."
    else
        echo "Operation cancelled."
    fi

elif [ "$COMMAND" == "download" ]; then
    DB_NAME=$SUBCOMMAND
    if [ -z "$DB_NAME" ]; then
        echo "❌ Please provide database name: ./slite download [db_name]"
        exit 1
    fi
    if [ -f "data/$DB_NAME.db" ]; then
        mkdir -p downloads
        cp "data/$DB_NAME.db" "downloads/${DB_NAME}_backup_$(date +%F_%H-%M).db"
        echo "✅ Database copied to: downloads/${DB_NAME}_backup_$(date +%F_%H-%M).db"
        echo "You can now download it via SCP or SFTP."
    else
        echo "❌ Database '$DB_NAME' does not exist."
    fi

elif [ "$COMMAND" == "init" ]; then
    echo "📂 Initializing SimpleLiteDB..."

    # 1. Buat Virtual Environment
    if [ ! -d "$VENV_DIR" ]; then
        echo "🌐 Creating Virtual Environment..."
        python3 -m venv $VENV_DIR || { echo "❌ Failed. Run: sudo apt install python3-venv"; exit 1; }
    else
        echo "ℹ️  Virtual Environment already exists."
    fi

    # 2. Install dependencies di VENV
    echo "📦 Installing dependencies..."
    $VENV_DIR/bin/pip install --upgrade pip
    $VENV_DIR/bin/pip install -r requirements.txt

    mkdir -p data

    # 3. Firewall
    echo "🛡️  Configuring Firewall (UFW) for port $PORT..."
    if command -v ufw > /dev/null; then
        sudo ufw allow $PORT/tcp
        echo "✅ Port $PORT is now allowed."
    else
        echo "⚠️  UFW not found. Please ensure port $PORT is open manually."
    fi

    echo "✅ SimpleLiteDB is ready! Run: ./slite start db"

elif [ "$COMMAND" == "list" ] && [ "$SUBCOMMAND" == "db" ]; then
    echo "📂 List of Databases:"
    echo "--------------------------"
    printf "%-20s %-10s\n" "Database Name" "Size"
    echo "--------------------------"
    for f in data/*.db; do
        [ -e "$f" ] || continue
        name=$(basename "$f" .db)
        size=$(du -sh "$f" | cut -f1)
        printf "%-20s %-10s\n" "$name" "$size"
    done
    echo "--------------------------"

elif [ "$COMMAND" == "log" ]; then
    if [ ! -f "$LOG_FILE" ]; then
        echo "⚠️  No log file found."
        exit 1
    fi
    echo "📄 Showing logs (Ctrl+C to stop)..."
    tail -f $LOG_FILE

elif [ "$COMMAND" == "help" ] || [ -z "$COMMAND" ]; then
    echo "   _____ _ _ _            _____  ____  "
    echo "  / ____| (_) |          |  __ \|  _ \ "
    echo " | (___ | |_| |_ ___     | |  | | |_) |"
    echo "  \___ \| | | __/ _ \    | |  | |  _ < "
    echo "  ____) | | | ||  __/    | |__| | |_) |"
    echo " |_____/|_|_|\__\___|    |_____/|____/ "
    echo "                                       "
    echo "SimpleLiteDB CLI - SQLite over HTTP Service"
    echo ""
    echo "Usage: ./slite [command] [subcommand] [option]"
    echo ""
    echo "Database Management:"
    echo "  init               Setup VENV, install deps & firewall"
    echo "  create db --api    Create new database & API key"
    echo "  list db            List all databases & sizes"
    echo "  refresh [name]     Empty/reset a database"
    echo "  delete [name]      Delete database & API key"
    echo "  download [name]    Create backup in /downloads"
    echo ""
    echo "Service Control:"
    echo "  start db           Start service in background (Port: $PORT)"
    echo "  stop db            Stop background service"
    echo "  log                View live service logs"
    echo ""
    echo "General:"
    echo "  help               Show this help message"
    echo ""

else
    ./slite help
fi
